{# imm_gen.v.j2 — Jinja2 template for the Immediate Generator
   Rendered by rtl_renderer.py from microarch.yaml. ZERO LLM tokens.

   Verilog {N{x}} replication conflicts with Jinja2 {{ }}  delimiters.
   Fix: use lb/rb variables for literal braces, and all widths pre-computed in Python.

   Context injected by build_imm_gen_context():
     mod_name, arch_name, xlen, imm_w
     imm_enc    : dict  {"I":"000","S":"001",...}
     imm_formats: dict  {"I":{"bits":12,"note":"..."}, ...}
     sign_ext   : dict  {"I":20,"S":20,"B":19,"J":11}  — pre-computed sign-rep widths
#}
{%- set lb = '{' -%}
{%- set rb = '}' -%}
// ============================================================
// {{ mod_name }}.v — Immediate Generator
// Generated by rtl_renderer.py from microarch.yaml
// Architecture : {{ arch_name }}
// XLEN         : {{ xlen }}
// Formats      : {{ imm_enc.keys() | list | join(', ') }}
// IMM type wid : {{ imm_w }} bits
// DO NOT EDIT — regenerate from microarch.yaml
// ============================================================
module {{ mod_name }} (
    /* verilator lint_off UNUSED */
    input  logic [31:0]          instr,
    /* verilator lint_on UNUSED */
    input  logic [{{ imm_w - 1 }}:0] imm_type,
    output logic [{{ xlen - 1 }}:0]  imm
);

// Immediate type encodings (from microarch.yaml):
{% for fmt, bin_val in imm_enc.items() %}// {{ fmt }}-type = {{ imm_w }}'b{{ bin_val }}
{% endfor %}

always_comb begin
    case (imm_type)
{% if 'I' in imm_enc %}
        // ── I-type ─────────────────────────────────────────────
        // sign_ext({ instr[31:20] })  →  {{ sign_ext.I }}-bit sign replication
        {{ imm_w }}'b{{ imm_enc['I'] }}: imm = {{ lb }}{{ lb }}{{ sign_ext.I }}{{ lb }}instr[31]{{ rb }}{{ rb }}, instr[31:20]{{ rb }};

{% endif %}
{% if 'S' in imm_enc %}
        // ── S-type ─────────────────────────────────────────────
        // sign_ext({ instr[31:25], instr[11:7] })
        {{ imm_w }}'b{{ imm_enc['S'] }}: imm = {{ lb }}{{ lb }}{{ sign_ext.S }}{{ lb }}instr[31]{{ rb }}{{ rb }}, instr[31:25], instr[11:7]{{ rb }};

{% endif %}
{% if 'B' in imm_enc %}
        // ── B-type ─────────────────────────────────────────────
        // sign_ext({ instr[31], instr[7], instr[30:25], instr[11:8], 1'b0 })
        {{ imm_w }}'b{{ imm_enc['B'] }}: imm = {{ lb }}{{ lb }}{{ sign_ext.B }}{{ lb }}instr[31]{{ rb }}{{ rb }}, instr[31], instr[7], instr[30:25], instr[11:8], 1'b0{{ rb }};

{% endif %}
{% if 'U' in imm_enc %}
        // ── U-type ─────────────────────────────────────────────
        // { instr[31:12], 12'b0 }
        {{ imm_w }}'b{{ imm_enc['U'] }}: imm = {{ lb }}instr[31:12], 12'b0{{ rb }};

{% endif %}
{% if 'J' in imm_enc %}
        // ── J-type ─────────────────────────────────────────────
        // sign_ext({ instr[31], instr[19:12], instr[20], instr[30:21], 1'b0 })
        {{ imm_w }}'b{{ imm_enc['J'] }}: imm = {{ lb }}{{ lb }}{{ sign_ext.J }}{{ lb }}instr[31]{{ rb }}{{ rb }}, instr[31], instr[19:12], instr[20], instr[30:21], 1'b0{{ rb }};

{% endif %}
        default: imm = {{ xlen }}'b0;
    endcase
end

endmodule
